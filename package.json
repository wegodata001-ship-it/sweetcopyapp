{
  "name": "sweetcopyapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "demo:hlwait:reset": "npx tsx scripts/demo-hlwait-reset.ts",
    "demo:setup": "npm run demo:hlwait:reset",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "prisma db seed",
    "db:sync": "prisma db push --accept-data-loss && prisma generate && prisma db seed",
    "icons:generate": "node scripts/generate-brand-icons.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource/noto-sans-hebrew": "^5.2.8",
    "@google-cloud/vision": "^4.3.2",
    "@napi-rs/canvas": "^1.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "fuse.js": "^7.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.14"
  }
}
