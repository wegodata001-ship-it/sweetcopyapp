{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "src/app/api/admin/employee-work/**",
    "src/app/api/admin/work-library/**",
    "src/app/api/admin/work-templates/**",
    "src/app/api/admin/work-assign/**",
    "src/app/api/admin/work-tasks/**",
    "src/app/api/admin/email-logs/**",
    "src/app/api/admin/debug/**",
    "src/app/api/cashflow/**",
    "src/app/api/checks/**",
    "src/app/api/documents/**",
    "src/app/api/workflows/**",
    "src/app/api/task-groups/**",
    "src/app/api/task-files/**",
    "src/app/api/staff/**",
    "src/app/api/recipes/**",
    "src/app/api/reports/**",
    "src/app/api/form-fields/**",
    "src/app/api/pdfs/**",
    "src/app/api/inventory/shelves/**",
    "src/app/api/inventory/count-**",
    "src/app/api/inventory/locations/**",
    "src/app/api/inventory/monthly-count/**",
    "src/app/api/inventory/stock/**",
    "src/app/api/inventory/stats/**",
    "src/app/api/inventory/movement-products/**",
    "src/app/api/inventory/meta/**",
    "src/app/api/inventory/categories/**",
    "src/app/api/inventory/count-history/**",
    "src/app/api/procurement/suppliers/*/products/**",
    "src/app/api/payments/*/pdf/**",
    "src/lib/work-tasks/**",
    "src/lib/workflows/**",
    "src/lib/checks/**",
    "src/lib/staff/**",
    "src/lib/ocr/**",
    "src/lib/pdf/**",
    "src/lib/notifications/**",
    "src/lib/email/**",
    "src/lib/procurement/**",
    "src/lib/tasks/**",
    "src/lib/work-status/**",
    "src/lib/work-sessions/**",
    "src/lib/inventory/**",
    "src/lib/finance/document-side-effects.ts",
    "src/lib/finance/cashflow-filters.ts",
    "src/lib/finance/cashflow-map.ts",
    "src/lib/finance/map-document.ts",
    "src/lib/finance/product-picker-catalog.ts",
    "src/lib/finance/expense-ledger-sync.ts",
    "src/lib/finance/sync-document-amounts.ts",
    "src/lib/finance/open-invoices.ts"
  ]
}
