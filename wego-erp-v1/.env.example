# Supabase (החלף בפרויקט החדש — לא לשתף מפתחות בקומיט)
# ל-DEMO: העתיקו .env.demo.example → .env.local (פרויקט Supabase נפרד בלבד)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — מחרוזת החיבור מ-Supabase → Database → Connection string (Transaction / Session)
DATABASE_URL=
# לרוב מיגרציות Prisma — Connection pooling או Direct לפי הגדרות Supabase
DIRECT_URL=

# =========================================
# DEMO mode (sweetcopyapp — customer demos only)
# =========================================
# APP_MODE=demo
# DEMO_ONLY=true
# DEMO_BLOCKED_SUPABASE_REFS=production-project-ref
# TENANT_DB_SCHEMA=demo
# NEXT_PUBLIC_TENANT_DB_SCHEMA=demo

# =========================================
# Multi-tenant schema (HLWAIT / DESIGMA / AMEER / WEGO …)
# =========================================
# שם ה-schema הפעיל — כל הקריאות עוברות דרך src/lib/tenant (לא hardcode בקוד)
TENANT_DB_SCHEMA=hlwait
# לדמו: hlwait_demo | desigma_demo | demo_*
NEXT_PUBLIC_TENANT_DB_SCHEMA=hlwait

# אם pooler (פורט 6543) נכשל ב-dev — חיבור ישיר: DATABASE_USE_DIRECT=true
# DATABASE_USE_DIRECT=true

# Storage — באקט אחד לדוחות PDF (public) + שם זהה ב-ENV
# 1) צרו ב-Supabase: Storage → New bucket → wego-reports → Public
# 2) חובה בשרת (העלאה עם SUPABASE_SERVICE_ROLE_KEY):
SUPABASE_STORAGE_BUCKET=wego-reports
# אופציונלי — אם הלקוח בונה URL ידנית (לרוב מספיק NEXT_PUBLIC_SUPABASE_URL)
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=wego-reports

# אימות — JWT לסשן (מחרוזת ארוכה ואקראית)
JWT_SECRET=

# אתחול SUPER ADMIN ראשון כשאין משתמשים במסד (אחרי מיגרציה)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# =========================================
# Email (Resend — https://resend.com)
# =========================================
RESEND_API_KEY=
MAIL_FROM=noreply@halawiyatquds.com
MAIL_FROM_NAME=WEGO BUSINESS ERP
APP_URL=https://halawiyatquds.com

# מצב בדיקה — כל המיילים רק לנמען הבדיקה (לא ללקוחות)
EMAIL_TEST_MODE=true
EMAIL_TEST_RECIPIENT=abulieltasneem23@gmail.com
# אופציונלי — קריאה ל-POST /api/debug/test-email בלי התחברות
EMAIL_TEST_SECRET=

# =========================================
# OCR — Google Vision (מומלץ לחשבוניות עברית/ערבית) או OCR.space (גיבוי)
# =========================================
# google_vision | ocr_space — ברירת מחדל: Vision אם מוגדר מפתח Google
OCR_PROVIDER=google_vision
# חובה — בלי מפתח אין OCR (אין fallback ל-OCR.space)
GOOGLE_CLOUD_VISION_API_KEY=
# לאפשר OCR.space שוב (רק לבדיקות): OCR_ALLOW_OCR_SPACE=1
# לאפשר regex fallback: OCR_ALLOW_TEXT_FALLBACK=1
# אפשרות 2: Service account JSON בשורה אחת
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# מסירה ללקוח — דשבורד 0, בלי אזהרות dev
SYSTEM_CLEAN_MODE=true

# גיבוי:
OCR_SPACE_API_KEY=
OCR_SPACE_ENGINE=2
