# =============================================================================
# DEMO ONLY — copy to .env.local (never commit real keys)
# Repository: https://github.com/wegodata001-ship-it/sweetcopyapp
# Use a SEPARATE Supabase project. Do not use production credentials.
# =============================================================================

APP_MODE=demo
DEMO_ONLY=true
NEXT_PUBLIC_APP_MODE=demo

# Block production Supabase project refs (comma-separated, from dashboard URL)
# Example: if production is https://abcdefgh.supabase.co → DEMO_BLOCKED_SUPABASE_REFS=abcdefgh
DEMO_BLOCKED_SUPABASE_REFS=

# --- Supabase DEMO project (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEMO_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres DEMO project (required) ---
DATABASE_URL=postgresql://postgres.YOUR_DEMO_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.YOUR_DEMO_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# --- App ---
NEXT_PUBLIC_APP_NAME=Sweet Demo
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=change-me-long-random-demo-only

# Storage (create public bucket in DEMO Supabase)
SUPABASE_STORAGE_BUCKET=wego-reports-demo

# Demo login users are seeded via: npx prisma db seed
#   superadmin or 100000018 / Admin123!  (SUPER_ADMIN)
#   admin                    / Admin123!  (ADMIN)
#   employee                 / Employee123!  (EMPLOYEE)

# Recommended for demos (no real emails / quiet UI)
EMAIL_TEST_MODE=true
SYSTEM_CLEAN_MODE=true

# Leave empty or use test keys only
RESEND_API_KEY=
OCR_SPACE_API_KEY=

# Do NOT set production super-admin bootstrap on demo DB
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
